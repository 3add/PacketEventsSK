test "IdPropTest":
    create new fake cow entity at test location for players and store it in {_e}
    assert {_e} is set with "Fake item display entity should be created"
    if {_id} isn't set:
        assert fake entity with id {_id} isn't {_e} with "Syntax should be correct - sometimes the id is set sometimes it isn't idk how to fix this its inconsistent"
    else:
        assert fake id of {_e} is set with "Syntax should be correct"