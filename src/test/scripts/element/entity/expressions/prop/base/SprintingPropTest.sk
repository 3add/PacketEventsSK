test "SilentPropTest":
    create new fake player entity at test location for {_viewers::*} and store it in {_e}:
        set fake sprinting state of {_e} to false
    assert {_e} is set with "fake entity should have been created"
    set the fake sprinting state of {_e} to true
    assert fake sprinting state of {_e} is true with "fake invisible state should be true"