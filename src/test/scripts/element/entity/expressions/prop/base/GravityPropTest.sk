test "GravityPropTest":
    create new fake player entity at test location for {_viewers::*} and store it in {_e}:
        set fake gravity state of {_e} to false
    assert {_e} is set with "fake entity should have been created"
    set the fake gravity state of {_e} to true
    assert fake gravity state of {_e} is true with "fake gravity state should be true"